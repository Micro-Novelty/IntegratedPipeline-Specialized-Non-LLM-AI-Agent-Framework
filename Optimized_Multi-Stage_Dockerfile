# Stage 1: Builder
FROM python:3.13-slim AS builder

RUN apt-get update && apt-get install -y \
    gcc g++ cython3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy and compile Cython code
COPY setup.py *.pyx .
RUN pip install --user numpy
RUN python setup.py build_ext --inplace

# Stage 2: Final
FROM python:3.13-slim

# Install ONLY runtime libraries
RUN apt-get update && apt-get install -y \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy compiled .so files
COPY --from=builder /build/*.so /app/

# Copy Python code
COPY . .

# Non-root user
RUN useradd -m -u 1000 aweuser && chown -R aweuser:aweuser /app
USER aweuser

CMD ["python", "main.py"]
